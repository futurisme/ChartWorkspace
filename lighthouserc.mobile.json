{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "- ready",
      "startServerReadyTimeout": 120000,
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/editor/0001",
        "http://localhost:3000/view/0001"
      ],
      "settings": {
        "preset": "mobile"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 280000 }],
        "mainthread-work-breakdown:scriptEvaluation": ["warn", { "maxNumericValue": 900 }],
        "total-blocking-time": ["error", { "maxNumericValue": 200 }]
      }
    }
  }
}
