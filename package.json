{
  "name": "chartmaker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node -e \"if(process.env.DATABASE_URL){require('child_process').execSync('npx prisma migrate deploy && npx prisma generate',{stdio:'inherit'})}else{console.log('Skipping prisma migrate/generate because DATABASE_URL not set')}\" && next build",
    "start": "next start",
    "lint": "next lint",
    "signaling": "node ./node_modules/y-webrtc/bin/server.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.0.0",
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.0.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "reactflow": "^11.9.0",
    "yjs": "^13.6.0",
    "y-webrtc": "^10.3.0",
    "@prisma/client": "^5.7.0"
  },
  "devDependencies": {
    "eslint": "^8.48.0",
    "eslint-config-next": "14.0.0",
    "prisma": "^5.7.0"
  }
}
