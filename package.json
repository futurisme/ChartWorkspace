{
  "name": "chartmaker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:signaling": "npm --prefix signaling-server run start",
    "install:signaling": "npm --prefix signaling-server install",
    "build": "npx prisma generate && node -e \"if(process.env.DATABASE_URL){try{require('child_process').execSync('npx prisma migrate deploy',{stdio:'inherit'})}catch(error){console.warn('Prisma migrate deploy failed during build, continuing without blocking deployment.');console.warn(error.message)}}else{console.log('Skipping prisma migrate deploy because DATABASE_URL not set')}\" && next build",
    "start": "next start",
    "lint": "next lint",
    "test:unit": "tsx --test src/features/flow/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "next": "^14.0.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.9.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "web-vitals": "^5.1.0",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "eslint": "^8.48.0",
    "eslint-config-next": "14.0.0",
    "prisma": "^5.7.0",
    "tsx": "^4.20.3"
  }
}
